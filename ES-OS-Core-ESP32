// --- Hardware Pins Configuration ---
#define PIN_NUM_MISO 19
#define PIN_NUM_MOSI 23
#define PIN_NUM_CLK  18
#define PIN_NUM_CS   5
#define PIN_NUM_DC   2
#define PIN_NUM_RST  4
#define PIN_NUM_BCKL 15

#define I2C_MASTER_SDA_IO 21
#define I2C_MASTER_SCL_IO 22
#define I2C_MASTER_NUM    I2C_NUM_1
#define I2C_MASTER_FREQ_HZ 400000

// Screen dimensions
#define HOR_RES 320
#define VER_RES 480
#define LVDISP_BUF_SIZE (HOR_RES * 40) // Double buffered 40 lines of pixels

/* ====================== HARDWARE DRIVERS & LOCKS ====================== */
static spi_device_handle_t spi_disp_handle;
static SemaphoreHandle_t lvgl_mutex = NULL;

static lv_disp_draw_buf_t draw_buf;
static lv_color_t *buf1 = NULL;
static lv_color_t *buf2 = NULL;
static lv_disp_drv_t disp_drv;

// Fast DMA SPI transmission write command helper
static void spi_send_cmd(const uint8_t cmd) {
    spi_transaction_t t;
    memset(&t, 0, sizeof(t));
    t.length = 8;
    t.tx_buffer = &cmd;
    t.user = (void*)0; // D/C line LOW for command
    spi_device_polling_transmit(spi_disp_handle, &t);
}

// Fast DMA SPI transmission write data helper
static void spi_send_data(const uint8_t *data, int len) {
    if (len == 0) return;
    spi_transaction_t t;
    memset(&t, 0, sizeof(t));
    t.length = len * 8;
    t.tx_buffer = data;
    t.user = (void*)1; // D/C line HIGH for data
    spi_device_polling_transmit(spi_disp_handle, &t);
}

// Display D/C callback line driver interface
static void disp_spi_pre_transfer_callback(spi_transaction_t *t) {
    int dc = (int)t->user;
    gpio_set_level((gpio_num_t)PIN_NUM_DC, dc);
}

// Hardware SPI Display Driver Initialization (ILI9488 / ILI9341 compatible)
static void init_display_hardware() {
    // Setup GPIO DC and Reset Pins
    gpio_config_t io_conf = {};
    io_conf.intr_type = GPIO_INTR_DISABLE;
    io_conf.mode = GPIO_MODE_OUTPUT;
    io_conf.pin_bit_mask = ((1ULL << PIN_NUM_DC) | (1ULL << PIN_NUM_RST) | (1ULL << PIN_NUM_BCKL));
    io_conf.pull_down_en = GPIO_PULLDOWN_DISABLE;
    io_conf.pull_up_en = GPIO_PULLUP_DISABLE;
    gpio_config(&io_conf);

    // Reset screen
    gpio_set_level((gpio_num_t)PIN_NUM_RST, 0);
    vTaskDelay(pdMS_TO_TICKS(100));
    gpio_set_level((gpio_num_t)PIN_NUM_RST, 1);
    vTaskDelay(pdMS_TO_TICKS(100));

    // Turn backlight ON
    gpio_set_level((gpio_num_t)PIN_NUM_BCKL, 1);

    // Initialize SPI bus
    spi_bus_config_t buscfg = {};
    buscfg.miso_io_num = PIN_NUM_MISO;
    buscfg.mosi_io_num = PIN_NUM_MOSI;
    buscfg.sclk_io_num = PIN_NUM_CLK;
    buscfg.quadwp_io_num = -1;
    buscfg.quadhd_io_num = -1;
    buscfg.max_transfer_sz = LVDISP_BUF_SIZE * sizeof(lv_color_t);

    spi_device_interface_config_t devcfg = {};
    devcfg.clock_speed_hz = 40 * 1000 * 1000; // 40 MHz SPI Clock
    devcfg.mode = 0;
    devcfg.spics_io_num = PIN_NUM_CS;
    devcfg.queue_size = 7;
    devcfg.pre_cb = disp_spi_pre_transfer_callback;

    spi_bus_initialize(SPI2_HOST, &buscfg, SPI_DMA_CH_AUTO);
    spi_bus_add_device(SPI2_HOST, &devcfg, &spi_disp_handle);

    // Send Init commands to LCD (Standard ILI9488 sequence)
    spi_send_cmd(0xE0); // Positive Gamma Control
    const uint8_t g_pos[] = {0x00, 0x03, 0x09, 0x08, 0x16, 0x0A, 0x3F, 0x78, 0x4C, 0x09, 0x0A, 0x08, 0x16, 0x1A, 0x0F};
    spi_send_data(g_pos, sizeof(g_pos));

    spi_send_cmd(0xE1); // Negative Gamma Control
    const uint8_t g_neg[] = {0x00, 0x16, 0x19, 0x03, 0x0F, 0x05, 0x32, 0x45, 0x46, 0x04, 0x0E, 0x0D, 0x35, 0x37, 0x0F};
    spi_send_data(g_neg, sizeof(g_neg));

    spi_send_cmd(0xC0); // Power Control 1
    const uint8_t pwr1[] = {0x17, 0x15};
    spi_send_data(pwr1, sizeof(pwr1));

    spi_send_cmd(0xC1); // Power Control 2
    const uint8_t pwr2[] = {0x41};
    spi_send_data(pwr2, sizeof(pwr2));

    spi_send_cmd(0x3A); // Interface Pixel Format
    const uint8_t fmt[] = {0x55}; // 16-bit RGB565
    spi_send_data(fmt, sizeof(fmt));

    spi_send_cmd(0x11); // Sleep Out
    vTaskDelay(pdMS_TO_TICKS(120));
    spi_send_cmd(0x29); // Display ON
}

// DMA-optimized display flush function
static void my_disp_flush_cb(lv_disp_drv_t *disp_drv, const lv_area_t *area, lv_color_t *color_p) {
    uint32_t w = (area->x2 - area->x1 + 1);
    uint32_t h = (area->y2 - area->y1 + 1);
    uint32_t len = w * h;

    // Column address set
    spi_send_cmd(0x2A);
    uint8_t col_data[] = {
        (uint8_t)(area->x1 >> 8), (uint8_t)(area->x1 & 0xFF),
        (uint8_t)(area->x2 >> 8), (uint8_t)(area->x2 & 0xFF)
    };
    spi_send_data(col_data, sizeof(col_data));

    // Page address set
    spi_send_cmd(0x2B);
    uint8_t row_data[] = {
        (uint8_t)(area->y1 >> 8), (uint8_t)(area->y1 & 0xFF),
        (uint8_t)(area->y2 >> 8), (uint8_t)(area->y2 & 0xFF)
    };
    spi_send_data(row_data, sizeof(row_data));

    // Memory write command
    spi_send_cmd(0x2C);
    
    // SPI Transmission of pixel array
    spi_send_data((uint8_t*)color_p, len * 2);

    lv_disp_flush_ready(disp_drv);
}

// Capacitive I2C Touch Driver Read Callback (GT911 compatible)
static void my_touchpad_read_cb(lv_indev_drv_t *indev_drv, lv_indev_data_t *data) {
    uint8_t touch_data[6];
    i2c_cmd_handle_t cmd = i2c_cmd_link_create();
    i2c_master_start(cmd);
    i2c_master_write_byte(cmd, (0x5D << 1) | I2C_MASTER_WRITE, true); // GT911 address
    i2c_master_write_byte(cmd, 0x81, true); // Status Register High
    i2c_master_write_byte(cmd, 0x4E, true); // Status Register Low
    i2c_master_start(cmd);
    i2c_master_write_byte(cmd, (0x5D << 1) | I2C_MASTER_READ, true);
    i2c_master_read(cmd, touch_data, sizeof(touch_data), I2C_MASTER_LAST_NACK);
    i2c_master_stop(cmd);
    esp_err_t ret = i2c_master_cmd_begin(I2C_MASTER_NUM, cmd, pdMS_TO_TICKS(10));
    i2c_cmd_link_delete(cmd);

    if (ret == ESP_OK && (touch_data[0] & 0x80) && (touch_data[0] & 0x0F) > 0) {
        data->state = LV_INDEV_STATE_PR;
        data->point.x = ((uint16_t)touch_data[3] << 8) | touch_data[2];
        data->point.y = ((uint16_t)touch_data[5] << 8) | touch_data[4];
    } else {
        data->state = LV_INDEV_STATE_REL;
    }

    // Reset buffer status register
    cmd = i2c_cmd_link_create();
    i2c_master_start(cmd);
    i2c_master_write_byte(cmd, (0x5D << 1) | I2C_MASTER_WRITE, true);
    i2c_master_write_byte(cmd, 0x81, true);
    i2c_master_write_byte(cmd, 0x4E, true);
    i2c_master_write_byte(cmd, 0x00, true); // Clear flag
    i2c_master_stop(cmd);
    i2c_master_cmd_begin(I2C_MASTER_NUM, cmd, pdMS_TO_TICKS(10));
    i2c_cmd_link_delete(cmd);
}

/* ====================== LVGL OS UI ENGINE ====================== */
class ES_UI_Engine {
public:
    static void init() {
        // Desktop Canvas
        lv_obj_t *desktop = lv_obj_create(lv_scr_act());
        lv_obj_set_size(desktop, LV_PCT(100), LV_PCT(100));
        lv_obj_set_style_bg_color(desktop, lv_color_make(15, 23, 42), 0); // Slate-900
        lv_obj_set_style_border_width(desktop, 0, 0);
        lv_obj_set_style_radius(desktop, 0, 0);

        // Status Bar Layout
        lv_obj_t *status_bar = lv_obj_create(desktop);
        lv_obj_set_size(status_bar, LV_PCT(100), 28);
        lv_obj_align(status_bar, LV_ALIGN_TOP_MID, 0, 0);
        lv_obj_set_style_bg_color(status_bar, lv_color_make(2, 44, 34), 0); // Opaque Dark Green
        lv_obj_set_style_border_width(status_bar, 0, 0);
        lv_obj_set_style_radius(status_bar, 0, 0);

        lv_obj_t *clock_label = lv_label_create(status_bar);
        lv_label_set_text(clock_label, "12:00");
        lv_obj_align(clock_label, LV_ALIGN_LEFT_MID, 10, 0);
        lv_obj_set_style_text_color(clock_label, lv_color_white(), 0);

        // Grid Application Icons
        lv_obj_t *app_grid = lv_obj_create(desktop);
        lv_obj_set_size(app_grid, LV_PCT(100), LV_PCT(70));
        lv_obj_align(app_grid, LV_ALIGN_CENTER, 0, 0);
        lv_obj_set_style_bg_opa(app_grid, LV_OPA_TRANSP, 0);
        lv_obj_set_style_border_width(app_grid, 0, 0);

        // Simulated launcher icons
        const char* apps[] = {"Chrome", "Files", "Settings", "PUBG 3D"};
        for (int i = 0; i < 4; i++) {
            lv_obj_t *btn = lv_btn_create(app_grid);
            lv_obj_set_size(btn, 64, 64);
            lv_obj_align(btn, LV_ALIGN_TOP_MID, (i - 1.5) * 75, 20);
            lv_obj_set_style_bg_color(btn, lv_color_make(59, 130, 246), 0);
            
            lv_obj_t *lbl = lv_label_create(btn);
            lv_label_set_text(lbl, apps[i]);
            lv_obj_align(lbl, LV_ALIGN_BOTTOM_MID, 0, 25);
            lv_obj_set_style_text_color(lbl, lv_color_white(), 0);
        }

        // Navigation Bar Layout
        lv_obj_t *nav_bar = lv_obj_create(desktop);
        lv_obj_set_size(nav_bar, LV_PCT(100), 48);
        lv_obj_align(nav_bar, LV_ALIGN_BOTTOM_MID, 0, 0);
        lv_obj_set_style_bg_color(nav_bar, lv_color_make(9, 0, 17), 0);
        lv_obj_set_style_border_width(nav_bar, 0, 0);
        lv_obj_set_style_radius(nav_bar, 0, 0);

        lv_obj_t *btn_home = lv_btn_create(nav_bar);
        lv_obj_set_size(btn_home, 40, 40);
        lv_obj_align(btn_home, LV_ALIGN_CENTER, 0, 0);
        lv_obj_t *home_lbl = lv_label_create(btn_home);
        lv_label_set_text(home_lbl, "O");
        lv_obj_align(home_lbl, LV_ALIGN_CENTER, 0, 0);
    }
};

/* ====================== MEMORY MANAGEMENT ====================== */
void *es_malloc(size_t size) {
    // Allocate high speed memory block from PSRAM/SPIRAM first, fallback to internal RAM
    void *ptr = heap_caps_malloc(size, MALLOC_CAP_8BIT | MALLOC_CAP_SPIRAM);
    if (!ptr) {
        ptr = heap_caps_malloc(size, MALLOC_CAP_8BIT | MALLOC_CAP_INTERNAL);
    }
    return ptr;
}

void es_free(void *ptr) {
    if (ptr) {
        heap_caps_free(ptr);
    }
}

/* ====================== LVGL ENGINE TICK & DUAL CORE SCHEDULING ====================== */
static void lvgl_tick_task(void *pvParameters) {
    while (1) {
        vTaskDelay(pdMS_TO_TICKS(10));
        lv_tick_inc(10);
    }
}

static void lvgl_gui_task(void *pvParameters) {
    lv_init();

    // Allocate memory-aligned double buffers for flicker-free DMA performance
    buf1 = (lv_color_t *)es_malloc(LVDISP_BUF_SIZE * sizeof(lv_color_t));
    buf2 = (lv_color_t *)es_malloc(LVDISP_BUF_SIZE * sizeof(lv_color_t));
    lv_disp_draw_buf_init(&draw_buf, buf1, buf2, LVDISP_BUF_SIZE);

    lv_disp_drv_init(&disp_drv);
    disp_drv.draw_buf = &draw_buf;
    disp_drv.flush_cb = my_disp_flush_cb;
    disp_drv.hor_res = HOR_RES;
    disp_drv.ver_res = VER_RES;
    lv_disp_drv_register(&disp_drv);

    // Register Capacitive Touchpad Driver
    static lv_indev_drv_t indev_drv;
    lv_indev_drv_init(&indev_drv);
    indev_drv.type = LV_INDEV_TYPE_POINTER;
    indev_drv.read_cb = my_touchpad_read_cb;
    lv_indev_drv_register(&indev_drv);

    // Build LVGL Graphics
    xSemaphoreTake(lvgl_mutex, portMAX_DELAY);
    ES_UI_Engine::init();
    xSemaphoreGive(lvgl_mutex);

    ESP_LOGI(ES_TAG, "LVGL: System Engine core successfully launched.");

    while (1) {
        vTaskDelay(pdMS_TO_TICKS(10));
        if (xSemaphoreTake(lvgl_mutex, pdMS_TO_TICKS(5)) == pdTRUE) {
            lv_timer_handler();
            xSemaphoreGive(lvgl_mutex);
        }
    }
}

/* ====================== MAIN INITIALIZATION ====================== */
extern "C" void app_main(void) {
    ESP_LOGI(ES_TAG, "E.S. OS Monolithic Kernel - Hardware Driver Start Sequence");

    // Init I2C for Capacitive Touch controller
    i2c_config_t conf = {};
    conf.mode = I2C_MODE_MASTER;
    conf.sda_io_num = I2C_MASTER_SDA_IO;
    conf.sda_pullup_en = GPIO_PULLUP_ENABLE;
    conf.scl_io_num = I2C_MASTER_SCL_IO;
    conf.scl_pullup_en = GPIO_PULLUP_ENABLE;
    conf.master.clk_speed = I2C_MASTER_FREQ_HZ;
    i2c_param_config(I2C_MASTER_NUM, &conf);
    i2c_driver_install(I2C_MASTER_NUM, conf.mode, 0, 0, 0);

    // Init display panel and SPI bus
    init_display_hardware();

    // Create RTOS Locks
    lvgl_mutex = xSemaphoreCreateMutex();

    // Task placement: Pin GUI Task to Core 0, Tick task to Core 1
    xTaskCreatePinnedToCore(lvgl_tick_task, "lvgl_tick", 2048, NULL, 6, NULL, 1);
    xTaskCreatePinnedToCore(lvgl_gui_task, "lvgl_gui", 16384, NULL, 5, NULL, 0);

    while (1) {
        vTaskDelay(pdMS_TO_TICKS(1000));
    }
}
