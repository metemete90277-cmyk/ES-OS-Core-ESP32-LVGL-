            lv_label_set_text(home_lbl, "O");
            lv_obj_align(home_lbl, LV_ALIGN_CENTER, 0, 0);
        }
    }
};

/* ====================== MEMORY MANAGEMENT ====================== */
void *es_malloc(size_t size) {
    void *ptr = heap_caps_malloc(size, MALLOC_CAP_8BIT | MALLOC_CAP_SPIRAM);
    if (!ptr) {
        ptr = heap_caps_malloc(size, MALLOC_CAP_8BIT | MALLOC_CAP_INTERNAL);
    }
    return ptr;
}

void es_free(void *ptr) {
    if (ptr) {
        heap_caps_free(ptr);
    }
}

/* ====================== LVGL ENGINE TICK & DUAL CORE SCHEDULING ====================== */
static void lvgl_tick_task(void *pvParameters) {
    while (1) {
        vTaskDelay(pdMS_TO_TICKS(10));
        lv_tick_inc(10);
    }
}

static void lvgl_gui_task(void *pvParameters) {
    lv_init();

    const size_t buffer_pixels = current_display.hor_res * 40;
    buf1 = (lv_color_t *)es_malloc(buffer_pixels * sizeof(lv_color_t));
    buf2 = (lv_color_t *)es_malloc(buffer_pixels * sizeof(lv_color_t));
    
    if (!buf1 || !buf2) {
        ESP_LOGE(ES_TAG, "Critical: UI Engine buffer allocation failed!");
        vTaskDelete(NULL);
        return;
    }
    
    lv_disp_draw_buf_init(&draw_buf, buf1, buf2, buffer_pixels);

    lv_disp_drv_init(&disp_drv);
    disp_drv.draw_buf = &draw_buf;
    disp_drv.flush_cb = my_disp_flush_cb;
    disp_drv.hor_res = current_display.hor_res;
    disp_drv.ver_res = current_display.ver_res;
    lv_disp_drv_register(&disp_drv);

    static lv_indev_drv_t indev_drv;
    lv_indev_drv_init(&indev_drv);
    indev_drv.type = LV_INDEV_TYPE_POINTER;
    indev_drv.read_cb = my_touchpad_read_cb;
    lv_indev_drv_register(&indev_drv);

    xSemaphoreTake(lvgl_mutex, portMAX_DELAY);
    ES_UI_Engine::init();
    xSemaphoreGive(lvgl_mutex);

    ESP_LOGI(ES_TAG, "LVGL: System Engine core successfully launched with dynamic display bindings.");

    while (1) {
        vTaskDelay(pdMS_TO_TICKS(10));
        if (xSemaphoreTake(lvgl_mutex, pdMS_TO_TICKS(5)) == pdTRUE) {
            lv_timer_handler();
            xSemaphoreGive(lvgl_mutex);
        }
    }
}

/* ====================== MAIN INITIALIZATION ====================== */
extern "C" void app_main(void) {
    ESP_LOGI(ES_TAG, "E.S. OS Monolithic Kernel - Dynamic Abstraction Setup Sequence");

    // Init I2C for Capacitive Touch controller and scan testing (I2C_NUM_1)
    i2c_config_t conf = {};
    conf.mode = I2C_MODE_MASTER;
    conf.sda_io_num = current_display.sda_pin;
    conf.sda_pullup_en = GPIO_PULLUP_ENABLE;
    conf.scl_io_num = current_display.scl_pin;
    conf.scl_pullup_en = GPIO_PULLUP_ENABLE;
    conf.master.clk_speed = 400000;
    i2c_param_config(I2C_NUM_1, &conf);
    i2c_driver_install(I2C_NUM_1, conf.mode, 0, 0, 0);

    // Scan connected peripherals dynamically
    scan_and_detect_display();

    // Init display panel and/or SPI bus depending on scanned device
    init_display_abstraction_layer();

    // Create RTOS Locks
    lvgl_mutex = xSemaphoreCreateMutex();

    // Task placement: Pin GUI Task to Core 0, Tick task to Core 1 (Stack size optimized to 1024)
    xTaskCreatePinnedToCore(lvgl_tick_task, "lvgl_tick", 1024, NULL, 6, NULL, 1);
    xTaskCreatePinnedToCore(lvgl_gui_task, "lvgl_gui", 16384, NULL, 5, NULL, 0);

    while (1) {
        vTaskDelay(pdMS_TO_TICKS(1000));
    }
}
